# PDFs in references (usually large files)
presentations/*/sources/references/*.pdf

# Generated outputs (optional to track)
presentations/*/output/

# Extracted PPTX content (generated)
pptx-extracted/

# Source PPTX files (usually large)
*.pptx

# Python virtual environment
.venv/

# Python bytecode
__pycache__/
*.pyc

# OS files
.DS_Store